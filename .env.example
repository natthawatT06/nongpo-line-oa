LINE_CHANNEL_ACCESS_TOKEN=put_your_messaging_api_channel_access_token_here
LINE_CHANNEL_SECRET=put_your_messaging_api_channel_secret_here
PUBLIC_WEB_URL=https://your-render-service.onrender.com
PUBLIC_LIFF_URL=https://liff.line.me/your-login-liff-id
PUBLIC_LIFF_URL_LOGIN=https://liff.line.me/your-login-liff-id
PUBLIC_LIFF_URL_START=https://liff.line.me/your-start-liff-id
VITE_LIFF_ID=put_your_line_login_liff_id_here
VITE_LIFF_ID_LOGIN=put_your_line_login_liff_id_here
VITE_LIFF_ID_START=put_your_line_start_liff_id_here
